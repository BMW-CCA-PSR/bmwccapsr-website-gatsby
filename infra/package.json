{
  "name": "aws-infra",
  "version": "0.2.0",
  "bin": {
    "aws-infra": "bin/aws-infra.ts"
  },
  "scripts": {
    "build": "tsc",
    "build:lambda": "node -e \"require('fs').mkdirSync('lambda-dist',{recursive:true})\" && npx esbuild lambda/msr-events-sync.ts --bundle --platform=node --format=cjs --target=node18 --external:crypto --external:buffer --external:path --external:fs --external:util --external:./xhr-sync-worker.js --outfile=lambda-dist/msr-events-sync.js && npx esbuild lambda/email-alias-sync.ts --bundle --platform=node --format=cjs --target=node18 --outfile=lambda-dist/email-alias-sync.js && cp node_modules/jsdom/lib/jsdom/living/xhr/xhr-sync-worker.js lambda-dist/xhr-sync-worker.js",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "npm run build:lambda && cdk"
  },
  "devDependencies": {
    "@aws-cdk/assert": "1.119.0",
    "@types/jest": "^26.0.10",
    "@types/node": "10.17.27",
    "aws-cdk": "1.119.0",
    "esbuild": "^0.19.12",
    "jest": "^26.4.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.2.0",
    "typescript": "~4.3.5"
  },
  "dependencies": {
    "@aws-cdk/aws-amplify": "1.119.0",
    "@aws-cdk/aws-apigateway": "1.119.0",
    "@aws-cdk/aws-certificatemanager": "1.119.0",
    "@aws-cdk/aws-codebuild": "1.119.0",
    "@aws-cdk/aws-codecommit": "1.119.0",
    "@aws-cdk/aws-codepipeline": "1.119.0",
    "@aws-cdk/aws-codepipeline-actions": "1.119.0",
    "@aws-cdk/aws-dynamodb": "1.119.0",
    "@aws-cdk/aws-ecs": "1.119.0",
    "@aws-cdk/aws-ecs-patterns": "1.119.0",
    "@aws-cdk/aws-elasticloadbalancingv2": "1.119.0",
    "@aws-cdk/aws-iam": "1.119.0",
    "@aws-cdk/aws-lambda": "1.119.0",
    "@aws-cdk/aws-route53": "1.119.0",
    "@aws-cdk/aws-secretsmanager": "1.119.0",
    "@aws-cdk/core": "1.119.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.917.0",
    "@aws-sdk/client-dynamodb": "3.1025.0",
    "@aws-sdk/client-eventbridge": "3.1012.0",
    "@aws-sdk/client-secrets-manager": "3.917.0",
    "@aws-sdk/util-dynamodb": "3.917.0",
    "@portabletext/html": "^1.0.0",
    "docker": "^1.0.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "jsdom": "^22.1.0",
    "source-map-support": "^0.5.16"
  }
}
